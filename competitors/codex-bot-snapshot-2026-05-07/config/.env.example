# Optional. Default is auto.
# auto tries no-key Yahoo chart data first, then keyed providers when present.
MARKET_DATA_PROVIDER=auto

# Optional free data keys. Use these for reliable scheduled cloud runs.
ALPHA_VANTAGE_API_KEY=
STOOQ_API_KEY=

# Optional. The default free-compatible Alpha Vantage function is TIME_SERIES_DAILY.
# Use TIME_SERIES_DAILY_ADJUSTED only if your key supports it.
ALPHA_VANTAGE_FUNCTION=TIME_SERIES_DAILY

# Optional display id for dashboard comparison.
BOT_ID=morning-quant-v1
